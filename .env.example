# ── Biwenger auth ────────────────────────────────────────────────────────────
# Bearer token — sácalo de DevTools (Network > XHR > Authorization)
# Se rota automáticamente cuando la UI lo actualiza (se guarda en .token)
BIWENGER_TOKEN=Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...

# Liga (no cambiar)
BIWENGER_LEAGUE_ID=2057487
BIWENGER_OWN_USER_ID=13532644

# ── Login del dashboard ───────────────────────────────────────────────────────
# Dos contraseñas → dos roles. "owner" ve todos los saldos (incluido el suyo),
# "guest" ve todos los saldos excepto el del propietario.
OWNER_PASSWORD=Shemas01
GUEST_PASSWORD=mongo
# Duración de la sesión en ms (por defecto 30 días)
SESSION_TTL_MS=2592000000
# Secreto para firmar las sesiones — si no se define, se genera y persiste en .session-secret
SESSION_SECRET=

# ── Alertas de mercado por email ─────────────────────────────────────────────
ALERT_EMAIL=gabrieliniesta2002@gmail.com

# SMTP — Gmail: usa una "App Password" (no tu contraseña normal)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu.cuenta@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Umbrales de alerta
MIN_DISCOUNT=0.10   # 10% de descuento mínimo (0.20 = 20%)
MIN_PRICE=1000000   # Solo jugadores con valor de mercado > 1M
CHECK_EVERY=300000  # Cada 5 minutos (en ms). 600000 = 10 min
